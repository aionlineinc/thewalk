{
  "extends": "next/core-web-vitals",
  "overrides": [
    {
      "files": ["src/app/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "@/lib/prisma",
                "message": "Do not import Prisma in the app layer. Use `@/server/services` or module services."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/modules/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@/app/*", "@/app/**"],
                "message": "Modules must not import the app layer."
              }
            ]
          }
        ]
      }
    }
  ]
}
