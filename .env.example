DATABASE_URL="postgresql://postgres:postgres@localhost:5432/thewalk?schema=public"
AUTH_SECRET="replace-with-strong-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional analytics
NEXT_PUBLIC_GA_ID=""

# Stripe (Phase 2/3)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Directus CMS
# Server-side URL (prefer an internal address in prod, e.g. http://cms:8055).
# Defaults to https://cms.thewalk.org when unset.
DIRECTUS_URL="http://localhost:8055"
# Optional: public URL used for browser links to the Directus admin UI.
# Defaults to https://cms.thewalk.org.
NEXT_PUBLIC_DIRECTUS_URL="https://cms.thewalk.org"
# Public URL used by the Next.js Image component to load CMS-hosted assets.
# Must be reachable from the browser. Defaults to https://cms.thewalk.org.
NEXT_PUBLIC_CMS_URL="https://cms.thewalk.org"
# Optional: static admin token so the app can read drafts/archived content
# (public read policy already covers status == "published" without a token).
DIRECTUS_TOKEN=""
# Optional overrides if collections are renamed in Directus.
DIRECTUS_ARTICLES_COLLECTION="articles"
DIRECTUS_COURSES_COLLECTION="courses"

# Shared secret for the /api/revalidate webhook called from Directus Flows.
# Generate with: openssl rand -hex 32
REVALIDATION_SECRET=""

# inLovingMemory (apps/inlovingmemory) + admin “Products” links (theWalk uses same DATABASE_URL)
# Local ILM dev server: http://localhost:3001
ILM_APP_URL=”http://localhost:3001”
# Connect8 (seed only; keep disabled in DB until live)
CONNECT8_APP_URL=”https://connect8.thewalk.org”

# ILM photo storage (S3-compatible: Wasabi, Cloudflare R2, MinIO, etc.)
# Without these, the Photos page shows “storage not configured” and uploads are disabled.
# Wasabi example:
#   ILM_S3_ENDPOINT=”https://s3.wasabisys.com”
#   ILM_S3_REGION=”us-east-1”
# Cloudflare R2 example:
#   ILM_S3_ENDPOINT=”https://$ACCOUNT_ID.r2.cloudflarestorage.com”
#   ILM_S3_REGION=”auto”
ILM_S3_BUCKET=””
ILM_S3_ENDPOINT=””
ILM_S3_REGION=”auto”
ILM_S3_ACCESS_KEY_ID=””
ILM_S3_SECRET_ACCESS_KEY=””
ILM_S3_PUBLIC_BASE_URL=””

